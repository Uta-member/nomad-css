{
  "name": "nomad-css",
  "version": "0.0.1",
  "description": "フレームワーク非依存のテーマ切り替え可能なCSSライブラリ。",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build:nomad-css-ui": "sass src/nomad-css-ui.scss:dist/css/nomad-css-ui.css --style=expanded --no-source-map",
    "build:default": "sass src/themes/default/default.scss:dist/css/default.css --style=expanded --no-source-map",
    "build:fluent2": "sass src/themes/fluent2/fluent2.scss:dist/css/fluent2.css --style=expanded --no-source-map",
    "build:material3": "sass src/themes/material3/material3.scss:dist/css/material3.css --style=expanded --no-source-map",
    "build:apple-hig": "sass src/themes/apple-hig/apple-hig.scss:dist/css/apple-hig.css --style=expanded --no-source-map",
    "build:material2": "sass src/themes/material2/material2.scss:dist/css/material2.css --style=expanded --no-source-map",
    "build:ant": "sass src/themes/ant/ant.scss:dist/css/ant.css --style=expanded --no-source-map",
    "build:bootstrap": "sass src/themes/bootstrap/bootstrap.scss:dist/css/bootstrap.css --style=expanded --no-source-map",
    "build:chakra": "sass src/themes/chakra/chakra.scss:dist/css/chakra.css --style=expanded --no-source-map",
    "build:material1": "sass src/themes/material1/material1.scss:dist/css/material1.css --style=expanded --no-source-map",
    "build:shadcn": "sass src/themes/shadcn/shadcn.scss:dist/css/shadcn.css --style=expanded --no-source-map",
    "build:primer": "sass src/themes/primer/primer.scss:dist/css/primer.css --style=expanded --no-source-map",
    "build:carbon": "sass src/themes/carbon/carbon.scss:dist/css/carbon.css --style=expanded --no-source-map",
    "build:daisyui": "sass src/themes/daisyui/daisyui.scss:dist/css/daisyui.css --style=expanded --no-source-map",
    "build:spectrum": "sass src/themes/spectrum/spectrum.scss:dist/css/spectrum.css --style=expanded --no-source-map",
    "build:win95": "sass src/themes/win95/win95.scss:dist/css/win95.css --style=expanded --no-source-map",
    "build:aqua": "sass src/themes/aqua/aqua.scss:dist/css/aqua.css --style=expanded --no-source-map",
    "build:holo": "sass src/themes/holo/holo.scss:dist/css/holo.css --style=expanded --no-source-map",
    "build:solarized": "sass src/themes/solarized/solarized.scss:dist/css/solarized.css --style=expanded --no-source-map",
    "build:nord": "sass src/themes/nord/nord.scss:dist/css/nord.css --style=expanded --no-source-map",
    "build:cyberpunk": "sass src/themes/cyberpunk/cyberpunk.scss:dist/css/cyberpunk.css --style=expanded --no-source-map",
    "build:terminal": "sass src/themes/terminal/terminal.scss:dist/css/terminal.css --style=expanded --no-source-map",
    "build:neumorphism": "sass src/themes/neumorphism/neumorphism.scss:dist/css/neumorphism.css --style=expanded --no-source-map",
    "build:glass": "sass src/themes/glass/glass.scss:dist/css/glass.css --style=expanded --no-source-map",
    "build:web20": "sass src/themes/web20/web20.scss:dist/css/web20.css --style=expanded --no-source-map",
    "build:skeuomorphic": "sass src/themes/skeuomorphic/skeuomorphic.scss:dist/css/skeuomorphic.css --style=expanded --no-source-map",
    "build:win7": "sass src/themes/win7/win7.scss:dist/css/win7.css --style=expanded --no-source-map",
    "build:linear": "sass src/themes/linear/linear.scss:dist/css/linear.css --style=expanded --no-source-map",
    "build:css": "npm run build:nomad-css-ui && npm run build:default && npm run build:fluent2 && npm run build:material3 && npm run build:apple-hig && npm run build:material2 && npm run build:ant && npm run build:bootstrap && npm run build:chakra && npm run build:material1 && npm run build:shadcn && npm run build:primer && npm run build:carbon && npm run build:daisyui && npm run build:spectrum && npm run build:win95 && npm run build:aqua && npm run build:holo && npm run build:solarized && npm run build:nord && npm run build:cyberpunk && npm run build:terminal && npm run build:neumorphism && npm run build:glass && npm run build:web20 && npm run build:skeuomorphic && npm run build:win7 && npm run build:linear",
    "build:showcase": "eleventy --input=showcase --output=_site",
    "build": "npm run build:css && npm run build:showcase",
    "watch:css": "sass --watch src/nomad-css-ui.scss:dist/css/nomad-css-ui.css src/themes/default/default.scss:dist/css/default.css src/themes/fluent2/fluent2.scss:dist/css/fluent2.css src/themes/material3/material3.scss:dist/css/material3.css src/themes/apple-hig/apple-hig.scss:dist/css/apple-hig.css src/themes/material2/material2.scss:dist/css/material2.css src/themes/ant/ant.scss:dist/css/ant.css src/themes/bootstrap/bootstrap.scss:dist/css/bootstrap.css src/themes/chakra/chakra.scss:dist/css/chakra.css src/themes/material1/material1.scss:dist/css/material1.css src/themes/shadcn/shadcn.scss:dist/css/shadcn.css src/themes/primer/primer.scss:dist/css/primer.css src/themes/carbon/carbon.scss:dist/css/carbon.css src/themes/daisyui/daisyui.scss:dist/css/daisyui.css src/themes/spectrum/spectrum.scss:dist/css/spectrum.css src/themes/win95/win95.scss:dist/css/win95.css src/themes/aqua/aqua.scss:dist/css/aqua.css src/themes/holo/holo.scss:dist/css/holo.css src/themes/solarized/solarized.scss:dist/css/solarized.css src/themes/nord/nord.scss:dist/css/nord.css src/themes/cyberpunk/cyberpunk.scss:dist/css/cyberpunk.css src/themes/terminal/terminal.scss:dist/css/terminal.css src/themes/neumorphism/neumorphism.scss:dist/css/neumorphism.css src/themes/glass/glass.scss:dist/css/glass.css src/themes/web20/web20.scss:dist/css/web20.css src/themes/skeuomorphic/skeuomorphic.scss:dist/css/skeuomorphic.css src/themes/win7/win7.scss:dist/css/win7.css src/themes/linear/linear.scss:dist/css/linear.css --no-source-map",
    "watch": "eleventy --input=showcase --output=_site --serve",
    "format": "prettier --write \"**/*.{scss,html,js,json,njk}\""
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "concurrently": "^9.2.1",
    "prettier": "^3.8.1",
    "sass": "^1.97.3"
  }
}
