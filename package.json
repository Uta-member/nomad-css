{
  "name": "nomad-css",
  "version": "0.0.1",
  "description": "フレームワーク非依存のテーマ切り替え可能なCSSライブラリ。",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build:default": "sass src/themes/default/default.scss:dist/css/default.css --style=expanded",
    "build:fluent2": "sass src/themes/fluent2/fluent2.scss:dist/css/fluent2.css --style=expanded",
    "build:material3": "sass src/themes/material3/material3.scss:dist/css/material3.css --style=expanded",
    "build:apple-hig": "sass src/themes/apple-hig/apple-hig.scss:dist/css/apple-hig.css --style=expanded",
    "build:material2": "sass src/themes/material2/material2.scss:dist/css/material2.css --style=expanded",
    "build:ant": "sass src/themes/ant/ant.scss:dist/css/ant.css --style=expanded",
    "build:bootstrap": "sass src/themes/bootstrap/bootstrap.scss:dist/css/bootstrap.css --style=expanded",
    "build:chakra": "sass src/themes/chakra/chakra.scss:dist/css/chakra.css --style=expanded",
    "build:css": "npm run build:default && npm run build:fluent2 && npm run build:material3 && npm run build:apple-hig && npm run build:material2 && npm run build:ant && npm run build:bootstrap && npm run build:chakra",
    "build:showcase": "eleventy --input=showcase --output=_site",
    "build": "npm run build:css && npm run build:showcase",
    "watch:css": "sass --watch src:dist/css",
    "watch": "eleventy --input=showcase --output=_site --serve",
    "format": "prettier --write \"**/*.{scss,html,js,json,njk}\""
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "concurrently": "^9.2.1",
    "prettier": "^3.8.1",
    "sass": "^1.97.3"
  }
}
