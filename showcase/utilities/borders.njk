---
title: Borders
layout: layout.njk
---

<section class="demo-section">
  <h1>Borders</h1>

  <!-- Border Sides -->
  <div class="demo-row">
    <div class="demo-label">Border</div>
    <div class="d-flex" style="gap: 1rem">
      <span class="border demo-box">.border</span>
      <span class="border-top demo-box">.border-top</span>
      <span class="border-end demo-box">.border-end</span>
      <span class="border-bottom demo-box">.border-bottom</span>
      <span class="border-start demo-box">.border-start</span>
    </div>
  </div>

  <!-- Border with Semantic Colors -->
  <div class="demo-row">
    <div class="demo-label">Border with Semantic Colors</div>
    <div class="d-flex flex-wrap" style="gap: 1rem">
      <span class="border palette primary demo-box"
        >.border.palette.primary</span
      >
      <span class="border palette secondary demo-box"
        >.border.palette.secondary</span
      >
      <span class="border palette success demo-box"
        >.border.palette.success</span
      >
      <span class="border palette warning demo-box"
        >.border.palette.warning</span
      >
      <span class="border palette danger demo-box">.border.palette.danger</span>
      <span class="border palette info demo-box">.border.palette.info</span>
    </div>
  </div>

  <!-- Border Width -->
  <div class="demo-row">
    <div class="demo-label">Border Width</div>
    <div class="d-flex" style="gap: 1rem">
      <span class="border border-1 demo-box">.border-1</span>
      <span class="border border-2 demo-box">.border-2</span>
      <span class="border border-3 demo-box">.border-3</span>
      <span class="border border-4 demo-box">.border-4</span>
      <span class="border border-5 demo-box">.border-5</span>
    </div>
  </div>

  <!-- Border Radius -->
  <div class="demo-row">
    <div class="demo-label">Border Radius</div>
    <div class="d-flex flex-wrap" style="gap: 1rem">
      <span class="border rounded-0 demo-box">.rounded-0</span>
      <span class="border rounded-1 demo-box">.rounded-1</span>
      <span class="border rounded-2 demo-box">.rounded-2</span>
      <span class="border rounded-3 demo-box">.rounded-3</span>
      <span class="border rounded-4 demo-box">.rounded-4</span>
      <span class="border rounded-5 demo-box">.rounded-5</span>
    </div>
  </div>

  <!-- Special Border Radius -->
  <div class="demo-row">
    <div class="demo-label">Special Border Radius</div>
    <div class="d-flex flex-wrap" style="gap: 1rem">
      <span class="border rounded demo-box">.rounded</span>
      <span
        class="border rounded-circle demo-box"
        style="
          width: 80px;
          height: 80px;
          display: flex;
          align-items: center;
          justify-content: center;
        "
        >.rounded-circle</span
      >
      <span class="border rounded-pill demo-box" style="padding: 1rem 2rem"
        >.rounded-pill</span
      >
    </div>
  </div>

  <!-- Directional Border Radius -->
  <div class="demo-row">
    <div class="demo-label">Directional Border Radius</div>
    <div class="d-flex flex-wrap" style="gap: 1rem">
      <span class="border rounded-5 rounded-bottom-0 demo-box"
        >.rounded-bottom-0</span
      >
      <span class="border rounded-5 rounded-start-0 demo-box"
        >.rounded-start-0</span
      >
      <span class="border rounded-5 rounded-top-0 demo-box"
        >.rounded-top-0</span
      >
      <span class="border rounded-5 rounded-end-0 demo-box"
        >.rounded-end-0</span
      >
    </div>
  </div>
</section>
