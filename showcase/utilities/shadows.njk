      >
      <span class="shadow-2 inset demo-box" style="padding: 1rem"
        >.shadow-2.inset</span
      >
      <span class="shadow-3 inset demo-box" style="padding: 1rem"
        >.shadow-3.inset</span
      >
      <span class="shadow-4 inset demo-box" style="padding: 1rem"
        >.shadow-4.inset</span
      >
      <span class="shadow-5 inset demo-box" style="padding: 1rem"
        >.shadow-5.inset</span
      >
    </div>
