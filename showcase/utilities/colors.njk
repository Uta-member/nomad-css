---
title: Colors
layout: layout.njk
---

{% set semanticNames = ["primary","secondary","tertiary","success","warning","danger","info","neutral"] %}
{% set familyNames = ["red","orange","amber","yellow","lime","green","emerald","teal","cyan","sky","blue","indigo","violet","purple","fuchsia","pink","rose"] %}
{% set neutralFamilyNames = ["slate","gray","zinc","stone"] %}

<section class="demo-section">
  <h1>Colors</h1>

  <!-- Semantic Levels -->
  <div class="demo-row">
    <h4>Semantic Levels</h4>
    <div class="d-flex flex-wrap" style="gap: 20px">
      {% for s in semanticNames %}
        <div class="{{ s }}" style="width: 160px">
          <div class="demo-label">{{ s | capitalize }}</div>
          <div class="container-semantic-color subtle">subtle</div>
          <div class="container-semantic-color tonal">tonal</div>
          <div class="container-semantic-color">solid</div>
          <div class="container-semantic-color strong">strong</div>
          <div class="container-semantic-color heavy">heavy</div>
        </div>
      {% endfor %}
    </div>
  </div>

  <!-- Named Scales -->
  <div class="demo-row">
    <h4>Named Scales (1-12)</h4>
    <div class="d-flex flex-wrap" style="gap: 12px">
      {% for f in familyNames %}
        <div style="width: 100px">
          <div class="demo-label">{{ f | capitalize }}</div>
          {% for n in range(1, 13) %}
            <div class="color-util-swatch bg-{{ f }}-{{ n }}">{{ n }}</div>
          {% endfor %}
        </div>
      {% endfor %}
    </div>
  </div>

  <!-- Neutral Scales -->
  <div class="demo-row">
    <h4>Neutral Scales (1-12)</h4>
    <div class="d-flex flex-wrap" style="gap: 12px">
      {% for f in neutralFamilyNames %}
        <div style="width: 100px">
          <div class="demo-label">{{ f | capitalize }}</div>
          {% for n in range(1, 13) %}
            <div class="color-util-swatch bg-{{ f }}-{{ n }}">{{ n }}</div>
          {% endfor %}
        </div>
      {% endfor %}
    </div>
  </div>

  {# ============================================ #}
  {# Color Utility Classes                        #}
  {# ============================================ #}

  <h2>Color Utility Classes</h2>

  {# --- Surface & Body Text --- #}
  <div class="demo-row">
    <h4>Surface &amp; Body Text</h4>
    <div style="margin-bottom: 0.75rem">
      <p class="demo-label">bg-surface-*</p>
      <div class="d-flex flex-wrap" style="gap: 4px">
        <div class="color-util-swatch bg-surface-overlay">bg-surface-overlay</div>
        <div class="color-util-swatch bg-surface-raised">bg-surface-raised</div>
        <div class="color-util-swatch bg-surface">bg-surface</div>
        <div class="color-util-swatch bg-surface-sunken">bg-surface-sunken</div>
        <div class="color-util-swatch bg-surface-deep">bg-surface-deep</div>
      </div>
    </div>
    <div>
      <p class="demo-label">text-body-*</p>
      <div class="d-flex flex-wrap" style="gap: 1.5rem">
        <span class="text-body">text-body</span>
        <span class="text-body-subtle">text-body-subtle</span>
        <span class="text-body-muted">text-body-muted</span>
        <span class="text-body-strong">text-body-strong</span>
      </div>
    </div>
  </div>

  {# --- Semantic bg/text named levels --- #}
  <div class="demo-row">
    <h4>bg-{semantic} — Named Levels</h4>
    <div class="d-flex flex-wrap" style="gap: 16px">
      {% for s in semanticNames %}
        <div style="min-width: 130px">
          <div class="demo-label">{{ s | capitalize }}</div>
          <div class="color-util-swatch bg-{{ s }}-subtle">bg-{{ s }}-subtle</div>
          <div class="color-util-swatch bg-{{ s }}-tonal">bg-{{ s }}-tonal</div>
          <div class="color-util-swatch bg-{{ s }}">bg-{{ s }}</div>
          <div class="color-util-swatch bg-{{ s }}-strong">bg-{{ s }}-strong</div>
          <div class="color-util-swatch bg-{{ s }}-heavy">bg-{{ s }}-heavy</div>
        </div>
      {% endfor %}
    </div>
  </div>

  <div class="demo-row">
    <h4>text-{semantic} — Named Levels</h4>
    <div class="d-flex flex-wrap" style="gap: 16px">
      {% for s in semanticNames %}
        <div style="min-width: 130px">
          <div class="demo-label">{{ s | capitalize }}</div>
          <div>
            <span class="text-{{ s }}-subtle" style="font-size: 0.825rem; display: block">text-{{ s }}-subtle</span>
            <span class="text-{{ s }}-tonal" style="font-size: 0.825rem; display: block">text-{{ s }}-tonal</span>
            <span class="text-{{ s }}" style="font-size: 0.825rem; display: block">text-{{ s }}</span>
            <span class="text-{{ s }}-strong" style="font-size: 0.825rem; display: block">text-{{ s }}-strong</span>
            <span class="text-{{ s }}-heavy" style="font-size: 0.825rem; display: block">text-{{ s }}-heavy</span>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>

  {# --- Family bg named levels --- #}
  <div class="demo-row">
    <h4>bg-{family} — Named Levels</h4>
    <div class="d-flex flex-wrap" style="gap: 16px">
      {% for h in familyNames %}
        <div style="min-width: 110px">
          <div class="demo-label">{{ h | capitalize }}</div>
          <div class="color-util-swatch bg-{{ h }}-subtle">subtle</div>
          <div class="color-util-swatch bg-{{ h }}-tonal">tonal</div>
          <div class="color-util-swatch bg-{{ h }}">solid</div>
          <div class="color-util-swatch bg-{{ h }}-strong">strong</div>
          <div class="color-util-swatch bg-{{ h }}-heavy">heavy</div>
        </div>
      {% endfor %}
    </div>
  </div>

  {# --- Numeric 1-12 (blue as example) --- #}
  <div class="demo-row">
    <h4>bg-{family}-{n} / text-{family}-{n} — Numeric Steps (blue)</h4>
    <div class="d-flex flex-wrap" style="gap: 24px">
      <div>
        <div class="demo-label">bg-blue-{n}</div>
        {% for n in range(1, 13) %}
          <div class="color-util-swatch bg-blue-{{ n }}">bg-blue-{{ n }}</div>
        {% endfor %}
      </div>
      <div style="padding: 0.5rem; border: 1px solid var(--border-color); border-radius: 4px">
        <div class="demo-label" style="margin-bottom: 0.25rem">text-blue-{n}</div>
        {% for n in range(1, 13) %}
          <div class="text-blue-{{ n }}" style="font-size: 0.825rem; font-family: monospace; margin-bottom: 2px">text-blue-{{ n }}</div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>
