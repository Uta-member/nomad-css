---
title: Button
layout: layout.njk
---

<section class="demo-section">
  <h1>Button</h1>

  <!-- Button NotStyled -->
  <div class="demo-row">
    <div class="demo-label">Button NotStyled</div>
    <button>Default</button>
    <button disabled>Disabled</button>
  </div>

  <!-- Button Variants -->
  <div class="demo-row">
    <div class="demo-label">Button Variants</div>
    <button class="button filled">Filled</button>
    <button class="button tonal">Tonal</button>
    <button class="button outlined">Outlined</button>
    <button class="button text">Text</button>
  </div>

  <!-- All Semantic Colors - Filled -->
  <div class="demo-row">
    <div class="demo-label">Filled Buttons (Semantic Colors)</div>
    <button class="button filled primary">Primary</button>
    <button class="button filled secondary">Secondary</button>
    <button class="button filled tertiary">Tertiary</button>
    <button class="button filled success">Success</button>
    <button class="button filled warning">Warning</button>
    <button class="button filled danger">Danger</button>
    <button class="button filled info">Info</button>
  </div>

  <!-- All Semantic Colors - Tonal -->
  <div class="demo-row">
    <div class="demo-label">Tonal Buttons (Semantic Colors)</div>
    <button class="button tonal primary">Primary</button>
    <button class="button tonal secondary">Secondary</button>
    <button class="button tonal tertiary">Tertiary</button>
    <button class="button tonal success">Success</button>
    <button class="button tonal warning">Warning</button>
    <button class="button tonal danger">Danger</button>
    <button class="button tonal info">Info</button>
  </div>

  <!-- All Semantic Colors - Outlined -->
  <div class="demo-row">
    <div class="demo-label">Outlined Buttons (Semantic Colors)</div>
    <button class="button outlined primary">Primary</button>
    <button class="button outlined secondary">Secondary</button>
    <button class="button outlined tertiary">Tertiary</button>
    <button class="button outlined success">Success</button>
    <button class="button outlined warning">Warning</button>
    <button class="button outlined danger">Danger</button>
    <button class="button outlined info">Info</button>
  </div>

  <!-- All Semantic Colors - Text -->
  <div class="demo-row">
    <div class="demo-label">Text Buttons (Semantic Colors)</div>
    <button class="button text primary">Primary</button>
    <button class="button text secondary">Secondary</button>
    <button class="button text tertiary">Tertiary</button>
    <button class="button text success">Success</button>
    <button class="button text warning">Warning</button>
    <button class="button text danger">Danger</button>
    <button class="button text info">Info</button>
  </div>

  <!-- Size Variants -->
  <div class="demo-row">
    <div class="demo-label">Button Sizes</div>
    <button class="button filled primary xs">Extra Small</button>
    <button class="button filled primary sm">Small</button>
    <button class="button filled primary">Default</button>
    <button class="button filled primary lg">Large</button>
    <button class="button filled primary xl">Extra Large</button>
  </div>

  <!-- Disabled State -->
  <div class="demo-row">
    <div class="demo-label">Disabled Buttons</div>
    <button class="button filled primary" disabled>Filled</button>
    <button class="button tonal primary" disabled>Tonal</button>
    <button class="button outlined primary" disabled>Outlined</button>
    <button class="button text primary" disabled>Text</button>
  </div>

  <!-- Icon Buttons -->
  <div class="demo-row">
    <div class="demo-label">Icon + Text Buttons</div>
    <button class="button filled primary"><span>★</span> Star</button>
    <button class="button tonal success"><span>✓</span> Done</button>
    <button class="button outlined danger"><span>✕</span> Delete</button>
    <button class="button text secondary"><span>↓</span> Download</button>
  </div>

  <!-- Icon Button Sizes -->
  <div class="demo-row">
    <div class="demo-label">Icon + Text Button Sizes</div>
    <button class="button filled primary xs"><span>★</span> Xs</button>
    <button class="button filled primary sm"><span>★</span> Sm</button>
    <button class="button filled primary md"><span>★</span> Md</button>
    <button class="button filled primary lg"><span>★</span> Lg</button>
    <button class="button filled primary xl"><span>★</span> Xl</button>
  </div>

  <!-- Icon Only Buttons -->
  <div class="demo-row">
    <div class="demo-label">Icon Only Buttons (.icon-only)</div>
    <button class="button filled primary icon-only"><span>★</span></button>
    <button class="button tonal success icon-only"><span>✓</span></button>
    <button class="button outlined danger icon-only"><span>✕</span></button>
    <button class="button text secondary icon-only"><span>↓</span></button>
  </div>

  <!-- Icon Only Buttons - Sizes -->
  <div class="demo-row">
    <div class="demo-label">Icon Only Buttons Sizes</div>
    <button class="button filled primary icon-only xs"><span>★</span></button>
    <button class="button filled primary icon-only sm"><span>★</span></button>
    <button class="button filled primary icon-only"><span>★</span></button>
    <button class="button filled primary icon-only lg"><span>★</span></button>
    <button class="button filled primary icon-only xl"><span>★</span></button>
  </div>
</section>
