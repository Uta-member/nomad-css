---
title: Badge
layout: layout.njk
---

<section class="demo-section">
  <h1>Badge</h1>

  <!-- Semantic Colors -->
  <div class="demo-row">
    <div class="demo-label">Badge (Semantic Colors)</div>
    <div
      style="display: flex; gap: 0.75rem; flex-wrap: wrap; align-items: center"
    >
      <span class="badge primary">Primary</span>
      <span class="badge secondary">Secondary</span>
      <span class="badge tertiary">Tertiary</span>
      <span class="badge success">Success</span>
      <span class="badge warning">Warning</span>
      <span class="badge danger">Danger</span>
      <span class="badge info">Info</span>
    </div>
  </div>

  <!-- Sizes -->
  <div class="demo-row">
    <div class="demo-label">Badge Sizes</div>
    <div style="display: flex; gap: 0.75rem; align-items: center">
      <span class="badge primary sm">Small</span>
      <span class="badge primary">Default</span>
      <span class="badge primary lg">Large</span>
    </div>
  </div>

  <!-- Dot Badge -->
  <div class="demo-row">
    <div class="demo-label">Badge Dot (.dot)</div>
    <div
      style="display: flex; gap: 1rem; align-items: center; flex-wrap: wrap"
    >
      <span class="badge primary dot"></span>
      <span class="badge secondary dot"></span>
      <span class="badge success dot"></span>
      <span class="badge warning dot"></span>
      <span class="badge danger dot"></span>
      <span class="badge info dot"></span>
    </div>
  </div>

  <!-- Overlay Badge -->
  <div class="demo-row">
    <div class="demo-label">Badge Overlay (.overlay)</div>
    <div style="display: flex; gap: 2rem; align-items: center">
      <div style="position: relative; display: inline-block">
        <button class="button filled primary">Messages</button>
        <span class="badge danger overlay">5</span>
      </div>
      <div style="position: relative; display: inline-block">
        <button class="button outlined secondary">Notifications</button>
        <span class="badge danger dot overlay"></span>
      </div>
    </div>
  </div>
</section>
