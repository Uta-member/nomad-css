---
title: Divider
layout: layout.njk
---

<section class="demo-section">
  <h1>Divider</h1>

  <!-- Horizontal Divider -->
  <div class="demo-row">
    <div class="demo-label">Horizontal Divider (hr.divider)</div>
    <p>Content above</p>
    <hr class="divider" />
    <p>Content below</p>
  </div>

  <!-- Text Divider -->
  <div class="demo-row">
    <div class="demo-label">Text Divider (div.divider)</div>
    <div class="divider">Section Title</div>
    <div class="divider">OR</div>
  </div>

  <!-- Vertical Divider -->
  <div class="demo-row">
    <div class="demo-label">Vertical Divider (span.divider.vertical)</div>
    <div style="display: flex; align-items: center">
      <span>Left Content</span>
      <span class="divider vertical"></span>
      <span>Middle Content</span>
      <span class="divider vertical"></span>
      <span>Right Content</span>
    </div>
  </div>
</section>
