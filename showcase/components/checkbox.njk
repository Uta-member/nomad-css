---
title: Checkbox
layout: layout.njk
---

<section class="demo-section">
  <h1>Checkbox</h1>

  <!-- Checkbox NotStyled -->
  <div class="demo-row">
    <div class="demo-label">Checkbox (NotStyled)</div>
    <div style="display: flex; gap: 2rem; flex-wrap: wrap">
      <label><input type="checkbox" /> Unchecked</label>
      <label><input type="checkbox" checked /> Checked</label>
      <label
        ><input type="checkbox" id="not-styled-indeterminate" />
        Indeterminate</label
      >
      <label><input type="checkbox" disabled /> Disabled</label>
      <label
        ><input type="checkbox" checked disabled /> Checked Disabled</label
      >
      <label
        ><input
          type="checkbox"
          id="not-styled-disabled-indeterminate"
          disabled
        />
        Indeterminate Disabled</label
      >
    </div>
    <script>
      document.getElementById("not-styled-indeterminate").indeterminate = true;
      document.getElementById(
        "not-styled-disabled-indeterminate"
      ).indeterminate = true;
    </script>
  </div>

  <!-- Checkbox Styled -->
  <div class="demo-row">
    <div class="demo-label">Checkbox (.checkbox)</div>
    <div style="display: flex; gap: 2rem; flex-wrap: wrap">
      <label class="form-check"
        ><input type="checkbox" class="checkbox" /> Unchecked</label
      >
      <label class="form-check"
        ><input type="checkbox" class="checkbox" checked /> Checked</label
      >
      <label class="form-check"
        ><input
          type="checkbox"
          class="checkbox"
          id="styled-indeterminate"
        />
        Indeterminate</label
      >
      <label class="form-check"
        ><input type="checkbox" class="checkbox" disabled />
        Disabled</label
      >
      <label class="form-check"
        ><input type="checkbox" class="checkbox" checked disabled />
        Checked Disabled</label
      >
      <label class="form-check"
        ><input
          type="checkbox"
          class="checkbox"
          id="styled-disabled-indeterminate"
          disabled
        />
        Indeterminate Disabled</label
      >
    </div>
    <script>
      document.getElementById("styled-indeterminate").indeterminate = true;
      document.getElementById(
        "styled-disabled-indeterminate"
      ).indeterminate = true;
    </script>
  </div>

  <!-- Checkbox Semantic Colors -->
  <div class="demo-row">
    <div class="demo-label">Checkbox Semantic Colors</div>
    <div style="display: flex; gap: 2rem; flex-wrap: wrap">
      <label
        ><input type="checkbox" class="checkbox primary" checked />
        Primary</label
      >
      <label
        ><input type="checkbox" class="checkbox secondary" checked />
        Secondary</label
      >
      <label
        ><input type="checkbox" class="checkbox tertiary" checked />
        Tertiary</label
      >
      <label
        ><input type="checkbox" class="checkbox success" checked />
        Success</label
      >
      <label
        ><input type="checkbox" class="checkbox warning" checked />
        Warning</label
      >
      <label
        ><input type="checkbox" class="checkbox danger" checked />
        Danger</label
      >
      <label
        ><input type="checkbox" class="checkbox info" checked />
        Info</label
      >
    </div>
  </div>

  <!-- Checkbox Sizes -->
  <div class="demo-row">
    <div class="demo-label">Checkbox Sizes</div>
    <div style="display: flex; gap: 2rem; flex-wrap: wrap">
      <label
        ><input type="checkbox" class="checkbox sm" checked /> Small</label
      >
      <label
        ><input type="checkbox" class="checkbox md" checked /> Medium</label
      >
      <label
        ><input type="checkbox" class="checkbox lg" checked /> Large</label
      >
    </div>
  </div>

  <!-- Checkbox Validation -->
  <div class="demo-row">
    <div class="demo-label">Validation (.is-invalid / .is-valid)</div>
    <div style="display: flex; flex-direction: column; gap: 1rem">
      <div>
        <label style="display: flex; align-items: center; gap: 0.5rem">
          <input type="checkbox" class="checkbox is-invalid" />
          同意する
        </label>
        <span class="form-hint invalid">同意が必要です</span>
      </div>
      <div>
        <label style="display: flex; align-items: center; gap: 0.5rem">
          <input type="checkbox" class="checkbox is-valid" checked />
          同意する
        </label>
        <span class="form-hint valid">同意されました</span>
      </div>
      <div>
        <label style="display: flex; align-items: center; gap: 0.5rem">
          <input type="checkbox" class="checkbox is-invalid" checked />
          同意する（checked 状態）
        </label>
        <span class="form-hint invalid">checked状態でもエラー植要生checked状態でもエラー表示可能</span>
      </div>
    </div>
  </div>
</section>
