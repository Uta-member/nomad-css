---
title: Avatar
layout: layout.njk
---

<section class="demo-section">
  <h1>Avatar</h1>

  <!-- Basic Avatar -->
  <div class="demo-row">
    <div class="demo-label">Avatar (Text Initials)</div>
    <div style="display: flex; gap: 1rem; align-items: center; flex-wrap: wrap">
      <span class="avatar primary">AB</span>
      <span class="avatar secondary">CD</span>
      <span class="avatar success">EF</span>
      <span class="avatar warning">GH</span>
      <span class="avatar danger">IJ</span>
      <span class="avatar info">KL</span>
    </div>
  </div>

  <!-- Avatar Sizes -->
  <div class="demo-row">
    <div class="demo-label">Avatar Sizes</div>
    <div style="display: flex; gap: 1rem; align-items: center">
      <span class="avatar primary sm">AB</span>
      <span class="avatar primary">AB</span>
      <span class="avatar primary lg">AB</span>
    </div>
  </div>

  <!-- Avatar Shapes -->
  <div class="demo-row">
    <div class="demo-label">Avatar Shapes</div>
    <div style="display: flex; gap: 1rem; align-items: center">
      <span class="avatar primary circle">AB</span>
      <span class="avatar primary rounded">AB</span>
      <span class="avatar primary square">AB</span>
    </div>
  </div>

  <!-- Avatar with Image -->
  <div class="demo-row">
    <div class="demo-label">Avatar with Image</div>
    <div style="display: flex; gap: 1rem; align-items: center">
      <span class="avatar">
        <img src="https://i.pravatar.cc/100?img=1" alt="User 1" />
      </span>
      <span class="avatar rounded">
        <img src="https://i.pravatar.cc/100?img=2" alt="User 2" />
      </span>
      <span class="avatar square">
        <img src="https://i.pravatar.cc/100?img=3" alt="User 3" />
      </span>
    </div>
  </div>
</section>
