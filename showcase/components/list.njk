---
title: List
layout: layout.njk
---

<section class="demo-section">
  <h1>List</h1>

  <!-- Plain List -->
  <div class="demo-row">
    <div class="demo-label">Plain List (.list)</div>
    <ul class="list" style="max-width: 300px">
      <li class="list-item">List Item 1</li>
      <li class="list-item">List Item 2</li>
      <li class="list-item active">Active Item</li>
      <li class="list-item">List Item 4</li>
      <li class="list-item disabled">Disabled Item</li>
    </ul>
  </div>

  <!-- List Group -->
  <div class="demo-row">
    <div class="demo-label">List Group (.list-group)</div>
    <ul class="list-group shadow-3" style="max-width: 300px">
      <li class="list-group-item">Group Item 1</li>
      <li class="list-group-item">Group Item 2</li>
      <li class="list-group-item active">Active Item</li>
      <li class="list-group-item">Group Item 4</li>
      <li class="list-group-item disabled">Disabled Item</li>
    </ul>
  </div>

  <!-- List Group with Links -->
  <div class="demo-row">
    <div class="demo-label">List Group with Links</div>
    <div class="list-group shadow-3" style="max-width: 300px">
      <a href="#" class="list-group-item">Clickable Item 1</a>
      <a href="#" class="list-group-item active">Active Clickable</a>
      <a href="#" class="list-group-item">Clickable Item 3</a>
      <a href="#" class="list-group-item disabled">Disabled</a>
    </div>
  </div>

  <!-- Link Group (navigation/disclosure style) -->
  <div class="demo-row">
    <div class="demo-label">Link Group (.link)</div>
    <div class="list-group shadow-3" style="max-width: 300px">
      <a href="#" class="list-group-item link">General</a>
      <a href="#" class="list-group-item link active">Profile</a>
      <a href="#" class="list-group-item link">Security</a>
      <a href="#" class="list-group-item link disabled">Billing (Disabled)</a>
    </div>
  </div>

  <!-- Link Group with Icon and Description -->
  <div class="demo-row">
    <div class="demo-label">Link Group with Icon &amp; Description</div>
    <div class="list-group shadow-3" style="max-width: 360px">
      <a href="#" class="list-group-item link">
        <span class="list-item-icon">⚙</span>
        <span class="list-item-body">
          <span>Settings</span>
          <span class="list-item-desc">Manage your account preferences</span>
        </span>
      </a>
      <a href="#" class="list-group-item link">
        <span class="list-item-icon">◎</span>
        <span class="list-item-body">
          <span>Notifications</span>
          <span class="list-item-desc">Control alerts and push notifications</span>
        </span>
      </a>
      <a href="#" class="list-group-item link">
        <span class="list-item-icon">⊠</span>
        <span class="list-item-body">
          <span>Privacy &amp; Security</span>
          <span class="list-item-desc">Review your security settings</span>
        </span>
      </a>
      <a href="#" class="list-group-item link disabled">
        <span class="list-item-icon">✦</span>
        <span class="list-item-body">
          <span>Billing</span>
          <span class="list-item-desc">Manage your subscription plan</span>
        </span>
      </a>
    </div>
  </div>
</section>
