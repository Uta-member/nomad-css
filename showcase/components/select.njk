---
title: Select
layout: layout.njk
---

<section class="demo-section">
  <h1>Select</h1>

  <!-- Select NotStyled -->
  <div class="demo-row">
    <div class="demo-label">Select (NotStyled)</div>
    <div
      style="display: flex; flex-direction: column; gap: 1rem; max-width: 400px"
    >
      <select>
        <option value="">Select an option</option>
        <option value="1">Option 1</option>
        <option value="2">Option 2</option>
        <option value="3">Option 3</option>
      </select>
      <select disabled>
        <option>Disabled select</option>
      </select>
    </div>
  </div>

  <!-- Select Basic -->
  <div class="demo-row">
    <div class="demo-label">Select (.select)</div>
    <div
      style="display: flex; flex-direction: column; gap: 1rem; max-width: 400px"
    >
      <select class="select">
        <option value="">Select an option</option>
        <option value="1">Option 1</option>
        <option value="2">Option 2</option>
        <option value="3">Option 3</option>
      </select>
      <select class="select" disabled>
        <option>Disabled select</option>
      </select>
    </div>
  </div>

  <!-- Select with Optgroup -->
  <div class="demo-row">
    <div class="demo-label">Select with Optgroup</div>
    <div style="max-width: 400px">
      <select class="select">
        <option value="">Select a fruit or vegetable</option>
        <optgroup label="Fruits">
          <option value="apple">Apple</option>
          <option value="banana">Banana</option>
          <option value="orange">Orange</option>
        </optgroup>
        <optgroup label="Vegetables">
          <option value="carrot">Carrot</option>
          <option value="broccoli">Broccoli</option>
          <option value="spinach">Spinach</option>
        </optgroup>
      </select>
    </div>
  </div>

  <!-- Select Sizes -->
  <div class="demo-row">
    <div class="demo-label">Select Sizes</div>
    <div
      style="display: flex; flex-direction: column; gap: 1rem; max-width: 400px"
    >
      <select class="select sm">
        <option value="">Small select</option>
        <option value="1">Option 1</option>
      </select>
      <select class="select">
        <option value="">Default select</option>
        <option value="1">Option 1</option>
      </select>
      <select class="select lg">
        <option value="">Large select</option>
        <option value="1">Option 1</option>
      </select>
    </div>
  </div>

  <!-- Select Variants -->
  <div class="demo-row">
    <div class="demo-label">Select Variants</div>
    <div
      style="display: flex; flex-direction: column; gap: 1rem; max-width: 400px"
    >
      <select class="select">
        <option value="">Default (outlined)</option>
        <option value="1">Option 1</option>
      </select>
      <select class="select filled">
        <option value="">Filled variant</option>
        <option value="1">Option 1</option>
      </select>
      <select class="select underline">
        <option value="">Underline variant</option>
        <option value="1">Option 1</option>
      </select>
    </div>
  </div>

  <!-- Select Semantic Colors -->
  <div class="demo-row">
    <div class="demo-label">Select Semantic Colors (focus to see)</div>
    <div
      style="display: flex; flex-direction: column; gap: 1rem; max-width: 400px"
    >
      <select class="select primary">
        <option value="">Primary focus</option>
        <option value="1">Option 1</option>
      </select>
      <select class="select secondary">
        <option value="">Secondary focus</option>
        <option value="1">Option 1</option>
      </select>
      <select class="select tertiary">
        <option value="">Tertiary focus</option>
        <option value="1">Option 1</option>
      </select>
      <select class="select success">
        <option value="">Success focus</option>
        <option value="1">Option 1</option>
      </select>
      <select class="select warning">
        <option value="">Warning focus</option>
        <option value="1">Option 1</option>
      </select>
      <select class="select danger">
        <option value="">Danger focus</option>
        <option value="1">Option 1</option>
      </select>
      <select class="select info">
        <option value="">Info focus</option>
        <option value="1">Option 1</option>
      </select>
    </div>
  </div>

  <!-- Multiple Select -->
  <div class="demo-row">
    <div class="demo-label">Multiple Select</div>
    <div style="max-width: 400px">
      <select class="select" multiple size="5">
        <option value="1">Option 1</option>
        <option value="2">Option 2</option>
        <option value="3">Option 3</option>
        <option value="4">Option 4</option>
        <option value="5">Option 5</option>
        <option value="6">Option 6</option>
      </select>
      <p style="margin-top: 0.5rem; font-size: 0.875rem; color: #666">
        Ctrl+クリックで複数選択できます
      </p>
    </div>
  </div>

  <!-- Select Validation -->
  <div class="demo-row">
    <div class="demo-label">Validation (.is-invalid / .is-valid)</div>
    <div
      style="display: flex; flex-direction: column; gap: 1rem; max-width: 400px"
    >
      <div>
        <select class="select is-invalid">
          <option value="">選択してください</option>
          <option value="1">Option 1</option>
          <option value="2">Option 2</option>
        </select>
        <span class="form-hint invalid">項目を選択してください</span>
      </div>
      <div>
        <select class="select is-valid">
          <option value="1" selected>Option 1</option>
          <option value="2">Option 2</option>
        </select>
        <span class="form-hint valid">選択されました</span>
      </div>
      <div>
        <select class="select filled is-invalid">
          <option value="">選択してください</option>
          <option value="1">Option 1</option>
        </select>
        <span class="form-hint invalid">入力が必要です (filled)</span>
      </div>
      <div>
        <select class="select underline is-valid">
          <option value="1" selected>Option 1</option>
          <option value="2">Option 2</option>
        </select>
        <span class="form-hint valid">選択完了 (underline)</span>
      </div>
    </div>
  </div>
</section>
