---
title: Accordion
layout: layout.njk
---

<section class="demo-section">
  <h1>Accordion</h1>

  <!-- Single Accordion -->
  <div class="demo-row">
    <div class="demo-label">Single Accordion</div>
    <details class="accordion">
      <summary class="accordion-header">
        Accordion Header 1
        <span class="accordion-icon"></span>
      </summary>
      <div class="accordion-body">
        Accordion content. Lorem ipsum dolor sit amet, consectetur
        adipiscing elit. Sed do eiusmod tempor incididunt ut labore.
      </div>
    </details>
    <details class="accordion" open>
      <summary class="accordion-header">
        Accordion Header 2 (Open)
        <span class="accordion-icon"></span>
      </summary>
      <div class="accordion-body">
        This accordion is open by default. You can click the header to
        collapse it.
      </div>
    </details>
  </div>

  <!-- Accordion Group -->
  <div class="demo-row">
    <div class="demo-label">Accordion Group (.accordion-group)</div>
    <div class="accordion-group">
      <details class="accordion">
        <summary class="accordion-header">
          Section 1
          <span class="accordion-icon"></span>
        </summary>
        <div class="accordion-body">Content for section 1.</div>
      </details>
      <details class="accordion" open>
        <summary class="accordion-header">
          Section 2 (Open)
          <span class="accordion-icon"></span>
        </summary>
        <div class="accordion-body">Content for section 2.</div>
      </details>
      <details class="accordion">
        <summary class="accordion-header">
          Section 3
          <span class="accordion-icon"></span>
        </summary>
        <div class="accordion-body">Content for section 3.</div>
      </details>
    </div>
  </div>
</section>
