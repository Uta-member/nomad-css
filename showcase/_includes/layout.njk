<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ title }} — nomad-css</title>
    <link rel="stylesheet" href="{{ '/dist/css/default.css' | url }}" />
    <link rel="stylesheet" href="{{ '/dist/css/fluent2.css' | url }}" />
    <link rel="stylesheet" href="{{ '/dist/css/material3.css' | url }}" />
    <link rel="stylesheet" href="{{ '/dist/css/apple-hig.css' | url }}" />
    <link rel="stylesheet" href="{{ '/dist/css/material2.css' | url }}" />
    <link rel="stylesheet" href="{{ '/dist/css/ant.css' | url }}" />
    <link rel="stylesheet" href="{{ '/dist/css/bootstrap.css' | url }}" />
    <link rel="stylesheet" href="{{ '/dist/css/chakra.css' | url }}" />
    <link rel="stylesheet" href="{{ '/dist/css/material1.css' | url }}" />
    <link rel="stylesheet" href="{{ '/dist/css/shadcn.css' | url }}" />
    <link rel="stylesheet" href="{{ '/dist/css/primer.css' | url }}" />
    <link rel="stylesheet" href="{{ '/dist/css/carbon.css' | url }}" />
    <link rel="stylesheet" href="{{ '/dist/css/daisyui.css' | url }}" />
    <link rel="stylesheet" href="{{ '/dist/css/spectrum.css' | url }}" />
    <link rel="stylesheet" href="{{ '/dist/css/win95.css' | url }}" />
    <link rel="stylesheet" href="{{ '/dist/css/aqua.css' | url }}" />
    <link rel="stylesheet" href="{{ '/dist/css/holo.css' | url }}" />
    <link rel="stylesheet" href="{{ '/dist/css/solarized.css' | url }}" />
    <link rel="stylesheet" href="{{ '/dist/css/nord.css' | url }}" />
    <link rel="stylesheet" href="{{ '/dist/css/cyberpunk.css' | url }}" />
    <link rel="stylesheet" href="{{ '/dist/css/terminal.css' | url }}" />
    <link rel="stylesheet" href="{{ '/dist/css/neumorphism.css' | url }}" />
    <link rel="stylesheet" href="{{ '/dist/css/glass.css' | url }}" />
    <link rel="stylesheet" href="{{ '/dist/css/web20.css' | url }}" />
    <link rel="stylesheet" href="{{ '/dist/css/skeuomorphic.css' | url }}" />
    <link rel="stylesheet" href="{{ '/dist/css/win7.css' | url }}" />
    <link rel="stylesheet" href="{{ '/assets/demo.css' | url }}" />
    <script>
      // テーマを描画前に適用してフラッシュを防ぐ
      (function () {
        var theme = localStorage.getItem("nomad-theme") || "material3";
        var scheme = localStorage.getItem("nomad-scheme") || "light";
        document.documentElement.dataset.theme = theme;
        document.documentElement.dataset.colorScheme = scheme;
      })();
    </script>
  </head>
  <body>
    <header class="showcase-header">
      <div class="showcase-header-inner">
        <a href="{{ '/' | url }}" class="showcase-logo">
          <strong>nomad-css</strong>
        </a>
        <div class="showcase-controls">
          <div class="theme-switcher">
            <label for="theme-select"><strong>Theme:</strong></label>
            <select id="theme-select" class="select" onchange="setTheme(this.value)">
              <option value="">Default</option>
              <optgroup label="Design Systems">
                <option value="fluent2">Fluent 2</option>
                <option value="material3">Material 3</option>
                <option value="material2">Material 2</option>
                <option value="material1">Material 1 (Holo era)</option>
                <option value="apple-hig">Apple HIG</option>
                <option value="ant">Ant Design</option>
                <option value="bootstrap">Bootstrap 5</option>
                <option value="chakra">Chakra UI</option>
                <option value="shadcn">shadcn/ui</option>
                <option value="primer">GitHub Primer</option>
                <option value="carbon">IBM Carbon</option>
                <option value="daisyui">daisyUI</option>
                <option value="spectrum">Adobe Spectrum</option>
              </optgroup>
              <optgroup label="Retro &amp; Classic">
                <option value="win95">Windows 95</option>
                <option value="aqua">macOS Aqua</option>
                <option value="holo">Android Holo</option>
              </optgroup>
              <optgroup label="Aesthetic Trends">
                <option value="solarized">Solarized</option>
                <option value="nord">Nord</option>
                <option value="cyberpunk">Cyberpunk</option>
                <option value="terminal">Terminal</option>
                <option value="neumorphism">Neumorphism</option>
                <option value="glass">Glassmorphism</option>
              </optgroup>
              <optgroup label="Vintage &amp; Historical">
                <option value="web20">Web 2.0 (2006)</option>
                <option value="skeuomorphic">Skeuomorphic (2011)</option>
                <option value="win7">Windows 7 Aero</option>
              </optgroup>
            </select>
          </div>
          <div class="theme-switcher">
            <label for="scheme-select"><strong>Color Scheme:</strong></label>
            <select id="scheme-select" class="select" onchange="setScheme(this.value)">
              <option value="">Default</option>
              <option value="light">Light</option>
              <option value="dark">Dark</option>
            </select>
          </div>
        </div>
      </div>
    </header>

    <div class="showcase-layout">
      <aside class="showcase-sidebar">
        <nav>
          {% set homeUrl = '/' | url %}
          <a
            href="{{ homeUrl }}"
            class="sidebar-link sidebar-home{% if page.url == homeUrl %} active{% endif %}"
            >← Home</a
          >

          <div class="sidebar-group">
            <div class="sidebar-group-label">Utilities</div>
            {% for item in nav.utilities %}
              {% set itemUrl = ('/utilities/' + item.slug + '/') | url %}
              <a
                href="{{ itemUrl }}"
                class="sidebar-link{% if page.url == itemUrl %} active{% endif %}"
                >{{ item.title }}</a
              >
            {% endfor %}
          </div>

          <div class="sidebar-group">
            <div class="sidebar-group-label">Components</div>
            {% for item in nav.components %}
              {% set itemUrl = ('/components/' + item.slug + '/') | url %}
              <a
                href="{{ itemUrl }}"
                class="sidebar-link{% if page.url == itemUrl %} active{% endif %}"
                >{{ item.title }}</a
              >
            {% endfor %}
          </div>
        </nav>
      </aside>

      <main class="showcase-main">{{ content | safe }}</main>
    </div>

    <script>
      function setTheme(theme) {
        document.documentElement.dataset.theme = theme;
        localStorage.setItem("nomad-theme", theme);
        var sel = document.getElementById("theme-select");
        if (sel) sel.value = theme;
      }

      function setScheme(scheme) {
        document.documentElement.dataset.colorScheme = scheme;
        localStorage.setItem("nomad-scheme", scheme);
        var sel = document.getElementById("scheme-select");
        if (sel) sel.value = scheme;
      }

      // ページロード時にlocalStorageから復元してドロップダウンも同期
      var savedTheme = localStorage.getItem("nomad-theme") || "material3";
      var savedScheme = localStorage.getItem("nomad-scheme") || "light";
      setTheme(savedTheme);
      setScheme(savedScheme);
    </script>
  </body>
</html>
